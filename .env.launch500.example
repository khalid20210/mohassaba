# Launch 500 - Production Environment Example
# انسخ هذا الملف إلى .env.production ثم عدّل القيم.

FLASK_ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=5001
BEHIND_PROXY=true
WAITRESS_THREADS=32

# Security
SECRET_KEY=CHANGE_ME_TO_STRONG_RANDOM_64_HEX
SESSION_COOKIE_SECURE=true

# Platform
PLATFORM_NAME=Jenan Biz
SAAS_REGION=sa

# Database (حالياً SQLite محسن)
# DB_PATH=database/accounting_prod.db
SQLITE_BUSY_TIMEOUT_MS=20000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_CACHE_SIZE=-30000

# Load protection
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUEST=300
HEALTH_DB_TIMEOUT_MS=1500

# Redis (required for distributed session + rate limiting)
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_BACKEND=redis
SESSION_REDIS_PREFIX=jenan:sess:
USE_REDIS_RATE_LIMIT=true
RATE_LIMIT_PREFIX=jenan:rl

# Queue (RQ)
QUEUE_BACKEND=rq
RQ_DEFAULT_QUEUE=default

# Strict startup checks (recommended for launch)
REDIS_REQUIRED=true
QUEUE_REQUIRED=true
FAIL_FAST_ON_STARTUP=true
