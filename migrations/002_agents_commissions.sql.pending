-- ════════════════════════════════════════════════════════════════════
-- 002_agents_commissions.sql
-- إضافة نظام المناديب والعمولات — مرحلة مستقبلية
-- هذا الملف معلّق وجاهز — لن يُطبَّق حتى يتم تفعيله
-- ════════════════════════════════════════════════════════════════════
-- لتفعيله: أزل الـ .pending من اسم الملف وابدأ تشغيل التطبيق

-- ────────────────────────────────────────────────────────────────────
-- !! لا تُشغّل هذا الملف إلا بعد مراجعة وموافقة المطوّر !!
-- !! سيتم تطبيقه تلقائياً في بيئة التطوير أولاً للاختبار !!
-- ────────────────────────────────────────────────────────────────────

-- جدول المناديب (Sales Agents)
CREATE TABLE IF NOT EXISTS agents (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    business_id     INTEGER NOT NULL REFERENCES businesses(id),
    user_id         INTEGER REFERENCES users(id),
    name            TEXT    NOT NULL,
    phone           TEXT,
    email           TEXT,
    commission_type TEXT    NOT NULL DEFAULT 'percentage',
    commission_rate REAL    NOT NULL DEFAULT 5.0,
    is_active       INTEGER NOT NULL DEFAULT 1,
    created_at      TEXT    NOT NULL DEFAULT (datetime('now'))
);

-- ربط المنادي بالفاتورة
ALTER TABLE invoices ADD COLUMN agent_id INTEGER REFERENCES agents(id);

-- جدول سجل العمولات
CREATE TABLE IF NOT EXISTS agent_commissions (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    agent_id        INTEGER NOT NULL REFERENCES agents(id),
    invoice_id      INTEGER NOT NULL REFERENCES invoices(id),
    invoice_total   REAL    NOT NULL,
    commission_rate REAL    NOT NULL,
    commission_amt  REAL    NOT NULL,
    status          TEXT    NOT NULL DEFAULT 'pending',
    paid_at         TEXT,
    notes           TEXT,
    created_at      TEXT    NOT NULL DEFAULT (datetime('now'))
);

-- فهرس للأداء
CREATE INDEX IF NOT EXISTS idx_commissions_agent    ON agent_commissions(agent_id);
CREATE INDEX IF NOT EXISTS idx_commissions_status   ON agent_commissions(status);
CREATE INDEX IF NOT EXISTS idx_invoices_agent       ON invoices(agent_id);
