# ══════════════════════════════════════════════════════════════════
# .env.example — نموذج متغيرات البيئة
# انسخ هذا الملف باسم .env وعدّل القيم حسب بيئتك
# لا ترفع ملف .env على GitHub أبداً!
# ══════════════════════════════════════════════════════════════════

# ── البيئة: development | production ──────────────────────────────
FLASK_ENV=development

# ── مفتاح التشفير (غيّره في الإنتاج بقيمة عشوائية قوية) ──────────
# توليد مفتاح: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── مسار قاعدة البيانات (اختياري — الافتراضي يعتمد على FLASK_ENV) ──
# DB_PATH=database/accounting_custom.db

# ── إعدادات الإنتاج ───────────────────────────────────────────────
# SESSION_COOKIE_SECURE=true   ← فعّله فقط مع HTTPS
# BEHIND_PROXY=true            ← فعّله إذا التطبيق خلف nginx/reverse proxy (يُصلح Rate Limiting)

# ── منصة SaaS (السعودية أولاً) ─────────────────────────────────────
PLATFORM_NAME=Jenan Biz
SAAS_REGION=sa

# ── تشغيل الخادم ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5001
DEBUG=false
WAITRESS_THREADS=16

# ── حماية الضغط (Rate Limiting) ───────────────────────────────────
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUEST=240

# ── فحوصات الصحة والجاهزية ────────────────────────────────────────
HEALTH_DB_TIMEOUT_MS=1500

# ── Redis + Sessions + Queue (للتوسع الحقيقي) ─────────────────────
# REDIS_URL=redis://localhost:6379/0
SESSION_BACKEND=filesystem
SESSION_REDIS_PREFIX=jenan:sess:
SESSION_FILE_DIR=instance/sessions

# تفعيل rate limit موزع عبر Redis (مهم عند تشغيل أكثر من نسخة)
USE_REDIS_RATE_LIMIT=false
RATE_LIMIT_PREFIX=jenan:rl

# Queue backend: sqlite | rq
QUEUE_BACKEND=sqlite
RQ_DEFAULT_QUEUE=default

# عند true: فشل Redis/Queue يجعل /readyz يرجع 503
REDIS_REQUIRED=false
QUEUE_REQUIRED=false

# ── تحسينات SQLite (مرحلة انتقالية قبل PostgreSQL) ───────────────
SQLITE_BUSY_TIMEOUT_MS=15000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_CACHE_SIZE=-20000

# ── Social OAuth (Google / Apple / Microsoft) ─────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
