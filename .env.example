# ══════════════════════════════════════════════════════════════════
# .env.example — نموذج متغيرات البيئة
# انسخ هذا الملف باسم .env وعدّل القيم حسب بيئتك
# لا ترفع ملف .env على GitHub أبداً!
# ══════════════════════════════════════════════════════════════════

# ── البيئة: development | production ──────────────────────────────
FLASK_ENV=development

# ── مفتاح التشفير (غيّره في الإنتاج بقيمة عشوائية قوية) ──────────
# توليد مفتاح: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── مسار قاعدة البيانات (اختياري — الافتراضي يعتمد على FLASK_ENV) ──
# DB_PATH=database/accounting_custom.db

# ── إعدادات الإنتاج ───────────────────────────────────────────────
# SESSION_COOKIE_SECURE=true   ← فعّله فقط مع HTTPS
